# Copier ce fichier en .env et remplir les valeurs nécessaires.
# Le pipeline fonctionne 100% en local/gratuit avec les valeurs par défaut ci-dessous
# (embeddings + reranker locaux, pas de clé API requise).

# --- Embeddings ---
# "local"  -> sentence-transformers (BAAI/bge-large-en-v1.5), gratuit, tourne sur CPU
# "openai" -> text-embedding-3-large, nécessite OPENAI_API_KEY
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_LOCAL=BAAI/bge-large-en-v1.5
EMBEDDING_MODEL_OPENAI=text-embedding-3-large
OPENAI_API_KEY=

# --- Reranking ---
# "local"  -> cross-encoder/ms-marco-MiniLM-L-6-v2, gratuit
# "cohere" -> rerank-english-v3.0, nécessite COHERE_API_KEY
RERANKER_PROVIDER=local
COHERE_API_KEY=

# --- Génération de la réponse finale ---
ANTHROPIC_API_KEY=
GENERATION_MODEL=claude-sonnet-4-6

# --- Base vectorielle ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=rag_portfolio

# --- Retrieval ---
TOP_K_DENSE=20
TOP_K_BM25=20
TOP_K_FINAL_AFTER_RERANK=5
RRF_K=60
